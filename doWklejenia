<!-- Sekcja: Podstawowe polecenia Tuxedo -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-6">
  <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
    ⚙️ Podstawowe polecenia Tuxedo
  </h2>

  <table class="w-full text-sm border-collapse">
    <tbody>
      <!-- tmboot -->
      <tr class="border-b border-gray-100 hover:bg-gray-50">
        <td class="py-3 px-4 font-medium text-gray-800">tmboot</td>
        <td class="text-gray-600">Uruchamia domenę, grupę lub pojedynczy serwer Tuxedo</td>
        <td class="text-right flex justify-end gap-2 px-4">
          <button onclick="copyCommand('tmboot -y', this)" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-xs font-medium">📋 Kopiuj</button>
          <button onclick="toggleParams(this)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-3 py-1 rounded text-xs font-medium">⚙️ Parametry</button>
        </td>
      </tr>
      <tr class="params-row hidden">
        <td colspan="3" class="px-4 py-3 bg-blue-50 border-b border-gray-100">
          <div class="text-xs text-gray-700">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
              <div><code class="bg-white px-1 rounded">-y</code> – nie pyta o potwierdzenie</div>
              <div><code class="bg-white px-1 rounded">-A</code> – uruchamia tylko BBL</div>
              <div><code class="bg-white px-1 rounded">-g grupa</code> – uruchamia grupę serwerów</div>
              <div><code class="bg-white px-1 rounded">-s nazwa</code> – uruchamia serwery o podanej nazwie</div>
              <div><code class="bg-white px-1 rounded">-S</code> – wszystkie serwery w sekcji SERVERS</div>
              <div><code class="bg-white px-1 rounded">-i ID</code> – uruchamia konkretny serwer</div>
            </div>
          </div>
        </td>
      </tr>

      <!-- tmshutdown -->
      <tr class="border-b border-gray-100 hover:bg-gray-50">
        <td class="py-3 px-4 font-medium text-gray-800">tmshutdown</td>
        <td class="text-gray-600">Zatrzymuje domenę, grupę lub pojedynczy serwer Tuxedo</td>
        <td class="text-right flex justify-end gap-2 px-4">
          <button onclick="copyCommand('tmshutdown -y', this)" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-xs font-medium">📋 Kopiuj</button>
          <button onclick="toggleParams(this)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-3 py-1 rounded text-xs font-medium">⚙️ Parametry</button>
        </td>
      </tr>
      <tr class="params-row hidden">
        <td colspan="3" class="px-4 py-3 bg-blue-50 border-b border-gray-100">
          <div class="text-xs text-gray-700">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
              <div><code class="bg-white px-1 rounded">-n</code> – tylko sprawdzenie poprawności (symulacja)</div>
              <div><code class="bg-white px-1 rounded">-y</code> – nie pyta o potwierdzenie</div>
              <div><code class="bg-white px-1 rounded">-w sek</code> – czeka X sekund na zatrzymanie</div>
              <div><code class="bg-white px-1 rounded">-k TERM|KILL</code> – wysyła sygnał zakończenia</div>
              <div><code class="bg-white px-1 rounded">-c</code> – zatrzymuje BBL mimo aktywnych klientów</div>
            </div>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>





  <script>
function toggleParams(button) {
  const row = button.closest('tr').nextElementSibling;
  row.classList.toggle('hidden');
}
</script>

  
