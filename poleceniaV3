<!-- Sekcja: Ustawienia i zarządzanie domenami Tuxedo -->
<section class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-6">
  <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
    ⚙️ Zarządzanie domenami Tuxedo
  </h2>

  <p class="text-sm text-red-600 mb-4">
    ⚠️ Czynności administracyjne wykonuj <b>tylko poza godzinami pracy użytkowników</b> lub w przypadku awarii!
  </p>

  <!-- Podsekcja: Podstawowe polecenia -->
  <div class="mb-6">
    <h3 class="text-xl font-semibold mb-2">Podstawowe polecenia</h3>
    <p class="mb-3">Polecenia do uruchamiania i zatrzymywania domen, grup lub pojedynczych serwerów Tuxedo:</p>

    <div class="space-y-3">
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm text-gray-800">tmboot -y</code>
        <button onclick="copyCommand('tmboot -y', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm text-gray-800">tmshutdown -y</code>
        <button onclick="copyCommand('tmshutdown -y', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
    </div>

    <ul class="list-disc ml-6 mt-3 text-sm text-gray-700">
      <li><b>-n</b> – sprawdzenie poprawności (symulacja)</li>
      <li><b>-y</b> – nie pyta o potwierdzenie</li>
      <li><b>-A</b> – uruchamia/zatrzymuje tylko BBL</li>
      <li><b>-g grupa</b> – operuje na grupie</li>
      <li><b>-s nazwa</b> – operuje na serwerach o nazwie</li>
      <li><b>-S</b> – wszystkie serwery w sekcji SERVERS</li>
      <li><b>-i ID</b> – konkretny serwer</li>
      <li><b>-w sek</b> – czeka określoną ilość sekund</li>
      <li><b>-k TERM|KILL</b> – wysyła sygnał TERM lub KILL</li>
      <li><b>-c</b> – zatrzymuje BBL mimo aktywnych klientów</li>
    </ul>
  </div>

  <!-- Podsekcja: Przykłady -->
  <div class="mb-6">
    <h3 class="text-xl font-semibold mb-2">Przykłady użycia</h3>
    <div class="space-y-3">
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">tmboot -i 10500 -g GR_WO</code>
        <button onclick="copyCommand('tmboot -i 10500 -g GR_WO', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">tmshutdown -yw9</code>
        <button onclick="copyCommand('tmshutdown -yw9', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">tmshutdown -i2020 -w2</code>
        <button onclick="copyCommand('tmshutdown -i2020 -w2', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
    </div>
  </div>

  <!-- Podsekcja: Skrypty administracyjne -->
  <div class="mb-6">
    <h3 class="text-xl font-semibold mb-2">Skrypty administracyjne (RBAC / użytkownik cwipw)</h3>
    <div class="space-y-3">
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">/appksi/bin/tuxstartstop.sh wylacz TJOPLAT</code>
        <button onclick="copyCommand('/appksi/bin/tuxstartstop.sh wylacz TJOPLAT', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">/appksi/bin/tuxstartstop.sh wylacz ODDSOI TJOSOI -yw2</code>
        <button onclick="copyCommand('/appksi/bin/tuxstartstop.sh wylacz ODDSOI TJOSOI -yw2', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">/appksi/bin/tuxstartstop.sh kill ODDSOI TJOSOI</code>
        <button onclick="copyCommand('/appksi/bin/tuxstartstop.sh kill ODDSOI TJOSOI', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">/appksi/bin/tuxstartstop.sh wlacz ODDSOI TJOSOI</code>
        <button onclick="copyCommand('/appksi/bin/tuxstartstop.sh wlacz ODDSOI TJOSOI', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
    </div>
  </div>

  <!-- Podsekcja: Operacje bazodanowe -->
  <div>
    <h3 class="text-xl font-semibold mb-2">Operacje bazodanowe (Informix)</h3>
    <p class="text-sm mb-2">Przykładowe ustawienia i zapytania dla bazy danych:</p>
    <div class="space-y-3">
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">. /appksi/ksi/dbadmin/ifx01seton</code>
        <button onclick="copyCommand('. /appksi/ksi/dbadmin/ifx01seton', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">SET ISOLATION TO DIRTY READ;</code>
        <button onclick="copyCommand('SET ISOLATION TO DIRTY READ;', this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
      <div class="bg-gray-50 p-3 rounded flex justify-between items-center">
        <code class="text-sm">UNLOAD TO 'ścieżka/do/pliku.csv' DELIMITER ',' SELECT * FROM t_audit_log;</code>
        <button onclick="copyCommand(\"UNLOAD TO 'ścieżka/do/pliku.csv' DELIMITER ',' SELECT * FROM t_audit_log;\", this)" class="copy-btn bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">📋 Kopiuj</button>
      </div>
    </div>
  </div>
</section>
