    <script>
        function copyCommand(command, button) {
            navigator.clipboard.writeText(command).then(function() {
                const originalText = button.innerHTML;
                const originalClass = button.className;
                
                button.innerHTML = '✅ Skopiowano!';
                button.classList.add('copied');
                
                showToast();
                
                setTimeout(() => {
                    button.innerHTML = originalText;
                    button.className = originalClass;
                }, 2000);
            }).catch(function(err) {
                console.error('Błąd kopiowania: ', err);
                button.innerHTML = '❌ Błąd';
                setTimeout(() => {
                    button.innerHTML = '📋 Kopiuj';
                }, 2000);
            });
        }

        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.remove('translate-x-full');
            setTimeout(() => {
                toast.classList.add('translate-x-full');
            }, 3000);
        }

        function updateStats() {
            const total = document.querySelectorAll('.command-row').length;
            const visible = document.querySelectorAll('.command-row:not([style*="display: none"])').length;
            document.getElementById('totalCount').textContent = total;
            document.getElementById('visibleCount').textContent = visible;
        }

        // Search functionality
        document.getElementById('searchInput').addEventListener('input', function(e) {
            filterCommands();
        });

        document.getElementById('categoryFilter').addEventListener('change', function(e) {
            filterCommands();
        });

        function toggleParams(button) {
            const row = button.closest('tr');
            const paramsRow = row.nextElementSibling;
            
            if (paramsRow && paramsRow.classList.contains('params-row')) {
                if (paramsRow.classList.contains('hidden')) {
                    paramsRow.classList.remove('hidden');
                    button.textContent = '📋 ukryj';
                } else {
                    paramsRow.classList.add('hidden');
                    button.textContent = '📋 parametry';
                }
            }
        }

        function filterCommands() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const categoryFilter = document.getElementById('categoryFilter').value;
            const rows = document.querySelectorAll('.command-row');
            
            rows.forEach(row => {
                const category = row.dataset.category;
                const description = row.cells[0].textContent.toLowerCase();
                const command = row.cells[1].textContent.toLowerCase();
                
                const matchesSearch = searchTerm === '' || description.includes(searchTerm) || command.includes(searchTerm);
                const matchesCategory = categoryFilter === '' || category === categoryFilter;
                
                if (matchesSearch && matchesCategory) {
                    row.style.display = '';
                    // Also show/hide corresponding params row
                    const paramsRow = row.nextElementSibling;
                    if (paramsRow && paramsRow.classList.contains('params-row')) {
                        paramsRow.style.display = matchesSearch && matchesCategory ? '' : 'none';
                    }
                } else {
                    row.style.display = 'none';
                    // Hide params row too
                    const paramsRow = row.nextElementSibling;
                    if (paramsRow && paramsRow.classList.contains('params-row')) {
                        paramsRow.style.display = 'none';
                    }
                }
            });
            
            updateStats();
        }

        // Initialize stats
        updateStats();
    </script>
